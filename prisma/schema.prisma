generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Definimos los roles permitidos a nivel de base de datos
enum Role {
  ADMIN
  RECEPCIONISTA
  CLIENTE
}

// Nuestra entidad en base de datos
model Categoria {
  id              Int      @id @default(autoincrement())
  nombre          String
  limitePorBloque Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relación inversa: Una categoría puede tener muchos bloques configurados
  bloques         BloqueConfig[]
}

model BloqueConfig {
  id        Int      @id @default(autoincrement())
  diaSemana Int      // Representaremos los días del 0 (Domingo) al 6 (Sábado)
  horaInicio String   // Guardaremos formato HH:MM (ej: "08:00")
  horaFin    String   // Guardaremos formato HH:MM (ej: "12:00")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con Categoría
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
}

// Nuevo modelo de Usuario con rol nativo
model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String   // Almacenaremos la contraseña (luego veremos cómo encriptarla)
  telefono  String?  // El signo de pregunta indica que es opcional (nullable)
  rol       Role     @default(CLIENTE) // Usa el enum que definimos arriba
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}